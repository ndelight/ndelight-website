{
    "rewrites": [
        {
            "source": "/events/:match*",
            "destination": "/event.html"
        },
        {
            "source": "/book/:match*",
            "destination": "/book.html"
        },
        {
            "source": "/water",
            "destination": "/water.html"
        },
        {
            "source": "/water/:match*",
            "destination": "/water.html"
        },
        {
            "source": "/water-order",
            "destination": "/water-order.html"
        },
        {
            "source": "/water-order/:match*",
            "destination": "/water-order.html"
        }
    ],
    "functions": {
        "api/**/*.js": {
            "memory": 1024,
            "maxDuration": 10
        }
    }
}